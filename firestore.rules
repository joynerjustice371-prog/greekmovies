rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['username','email','role','status'])
                    && request.resource.data.role == 'user'
                    && request.resource.data.status == 'active';

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role','status']))
                    || (request.auth != null
                        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      allow delete: if false;
    }

    // ── Series Ratings ─────────────────────────────────────────
    // Structure: seriesRatings/{seriesId}/ratings/{uid}
    // Anyone can read (to compute averages).
    // Authenticated users can only write their own rating doc.
    match /seriesRatings/{seriesId}/ratings/{uid} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.keys().hasAll(['rating', 'updatedAt'])
                   && request.resource.data.rating is int
                   && request.resource.data.rating >= 1
                   && request.resource.data.rating <= 5;
    }

    // ── Comments ───────────────────────────────────────────────
    match /comments/{seriesSlug}/items/{commentId} {
      allow read: if true;

      allow create: if request.auth != null
                    && exists(/databases/$(database)/documents/users/$(request.auth.uid))
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active'
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 2000;

      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes','dislikes']);

      allow delete: if request.auth != null
                    && (resource.data.userId == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
  }
}

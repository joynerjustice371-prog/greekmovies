rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────
    // Users can read/write their OWN document.
    // Admins can read all user documents.
    match /users/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['username','email','role','status'])
                    && request.resource.data.role == 'user'
                    && request.resource.data.status == 'active';

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    // Users cannot change their own role or status
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role','status']))
                    // Admins can change role/status
                    || (request.auth != null
                        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      allow delete: if false; // Never delete user docs directly
    }

    // ── Comments ───────────────────────────────────────────────
    // Anyone can read comments.
    // Authenticated non-banned users can post comments.
    // Users can only delete their own comments. Admins can delete any.
    match /comments/{seriesSlug}/items/{commentId} {
      allow read: if true;

      allow create: if request.auth != null
                    && exists(/databases/$(database)/documents/users/$(request.auth.uid))
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active'
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 2000;

      allow update: if request.auth != null
                    // Only allow updating likes/dislikes counters
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes','dislikes']);

      allow delete: if request.auth != null
                    && (resource.data.userId == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
  }
}

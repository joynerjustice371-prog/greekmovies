// ============================================================
// firestore.rules — StreamVault v2
// Structure:
//   users/{uid}                       — profile (email private)
//   users/{uid}/favorites/{seriesId}
//   users/{uid}/watchlist/{seriesId}
//   users/{uid}/ratings/{seriesId}
//   series/{seriesId}/comments/{commentId}
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS ─────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid) && validNewUser(request.resource.data);
      // Owner can update username/avatar; cannot change role or status
      allow update: if isOwner(uid)
                    && !('role'   in request.resource.data.diff(resource.data).affectedKeys())
                    && !('status' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if false;

      match /favorites/{seriesId} { allow read, write: if isOwner(uid); }
      match /watchlist/{seriesId} { allow read, write: if isOwner(uid); }
      match /ratings/{seriesId}   { allow read, write: if isOwner(uid); }
    }

    // ── SERIES → COMMENTS ─────────────────────────────────────
    match /series/{seriesId}/comments/{commentId} {
      // Public read — shadowban enforced client-side
      allow read: if true;

      // Only authenticated users can post
      allow create: if isLoggedIn()
                    && request.resource.data.uid == request.auth.uid
                    && validComment(request.resource.data);

      // Author can update own comment text
      allow update: if isLoggedIn()
                    && resource.data.uid == request.auth.uid
                    && onlyTextUpdated();

      // Anyone logged in can increment counters (likes/dislikes/reports)
      allow update: if isLoggedIn() && onlyCountersUpdated();

      // Author can soft-delete
      allow delete: if isLoggedIn() && resource.data.uid == request.auth.uid;
    }

    // ── CATCH-ALL DENY ────────────────────────────────────────
    match /{document=**} { allow read, write: if false; }
  }

  function isLoggedIn()   { return request.auth != null; }
  function isOwner(uid)   { return request.auth != null && request.auth.uid == uid; }

  function validNewUser(d) {
    return d.keys().hasAll(['username','email','avatar','role','status','createdAt'])
        && d.username is string && d.username.size() >= 3 && d.username.size() <= 50
        && d.email is string
        && d.avatar is string
        && d.role == 'user'
        && d.status == 'active';
  }

  function validComment(d) {
    return d.keys().hasAll(['uid','username','avatar','text','rating',
                             'likes','dislikes','status','reports','createdAt'])
        && d.uid is string
        && d.username is string
        && d.text is string && d.text.size() > 0 && d.text.size() <= 2000
        && d.rating is int && d.rating >= 0 && d.rating <= 5
        && d.likes == 0 && d.dislikes == 0 && d.reports == 0
        && d.status == 'visible';
  }

  function onlyTextUpdated() {
    return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text']);
  }

  function onlyCountersUpdated() {
    let k = request.resource.data.diff(resource.data).affectedKeys();
    return k.hasOnly(['likes']) || k.hasOnly(['dislikes'])
        || k.hasOnly(['reports']) || k.hasOnly(['likes','dislikes','reports']);
  }
}

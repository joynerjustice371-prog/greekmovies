rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn()
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users: profile document ───────────────────────────────
    // users/{uid}
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
                    && request.resource.data.keys().hasAll(['username','email','role','status'])
                    && request.resource.data.role   == 'user'
                    && request.resource.data.status == 'active';

      allow update: if (isOwner(userId)
                        && !request.resource.data.diff(resource.data)
                             .affectedKeys().hasAny(['role','status']))
                    || isAdmin();

      allow delete: if false;

      // ── Favorites subcollection: users/{uid}/favorites/{slug} ──
      // Simple doc: { addedAt: Timestamp }
      match /favorites/{slug} {
        allow read, write: if isOwner(userId);
      }

      // ── Watchlist subcollection: users/{uid}/watchlist/{slug} ──
      match /watchlist/{slug} {
        allow read, write: if isOwner(userId);
      }

      // ── Seen subcollection: users/{uid}/seen/{slug} ────────
      match /seen/{slug} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Series Ratings ─────────────────────────────────────────
    // seriesRatings/{seriesId}/ratings/{uid}
    // Doc: { rating: int 1-5, uid: string, updatedAt: Timestamp }
    // Anyone can read (to compute averages).
    // Auth user can only write their own rating doc.
    match /seriesRatings/{seriesId}/ratings/{uid} {
      allow read: if true;

      allow write: if isOwner(uid)
                   && request.resource.data.rating is int
                   && request.resource.data.rating >= 1
                   && request.resource.data.rating <= 5;
    }

    // ── Comments ───────────────────────────────────────────────
    // comments/{seriesSlug}/items/{commentId}
    match /comments/{seriesSlug}/items/{commentId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && exists(/databases/$(database)/documents/users/$(request.auth.uid))
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active'
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 2000;

      // Only likes/dislikes can be updated
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['likes','dislikes']);

      allow delete: if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
